# ── AWS Credentials ────────────────────────────────────────────────────────────
# Option A — named profile (recommended for local/EC2 with instance role)
AWS_PROFILE=default
AWS_REGION=ap-south-1

# Option B — explicit keys (use when profile is not available, e.g. CI/CD)
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Bedrock ────────────────────────────────────────────────────────────────────
# Primary model: planning, reasoning, complex analysis
BEDROCK_MODEL_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Secondary model: fast, cheap tasks (aliased as BEDROCK_HAIKU_MODEL_ID in settings)
BEDROCK_HAIKU_MODEL_ID=deepseek.v3-v1:0

# Optional per-agent model overrides.
# Leave commented to inherit BEDROCK_MODEL_ID.
# BEDROCK_MODEL_OBSERVABILITY_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MODEL_INFRA_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MODEL_DB_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MODEL_COST_ID=deepseek.v3-v1:0
# BEDROCK_MODEL_CICD_ID=deepseek.v3-v1:0
# BEDROCK_MODEL_TOOL_GENERATOR_ID=anthropic.claude-haiku-4-5-20251001-v1:0
# BEDROCK_MODEL_PLANNER_ID=anthropic.claude-haiku-4-5-20251001-v1:0

# Optional planner fast-path override (routing + direct answers).
# If unset, planner fast path uses BEDROCK_HAIKU_MODEL_ID.
# BEDROCK_MODEL_PLANNER_FAST_ID=deepseek.v3-v1:0

# Token / sampling controls (optional — defaults shown)
# BEDROCK_MAX_TOKENS=4096
# BEDROCK_TEMPERATURE=0.1

# ── Knowledge Base ─────────────────────────────────────────────────────────────
KNOWLEDGE_BASE_ID=your-knowledge-base-id
S3_BUCKET_NAME=autopilot-ai-knowledge-base

# Minimum cosine similarity to include a KB result (optional — default shown)
# KB_SIMILARITY_THRESHOLD=0.6

# ── GitHub ─────────────────────────────────────────────────────────────────────
# Personal access token — needs repo + workflow read scopes
GITHUB_TOKEN=your-github-token

# Comma-separated list of repos to poll for CI/CD events
# GITHUB_MONITORED_REPOS=my-org/backend,my-org/infra

# How often the poller checks for new commits (optional — default shown)
# GITHUB_POLL_INTERVAL_SECONDS=300

# ── Cost / Currency ────────────────────────────────────────────────────────────
CURRENCY=INR
USD_TO_INR_RATE=84.5

# ── Alerting ───────────────────────────────────────────────────────────────────
# Max seconds from anomaly detection to alert delivery (optional — default shown)
# ALERT_DELIVERY_SLA_SECONDS=60

# ── Analysis Thresholds ────────────────────────────────────────────────────────
# (all optional — defaults shown as comments)
# ANOMALY_SIGMA_THRESHOLD=2.0          # std-devs before a metric is flagged
# BUILD_REGRESSION_MULTIPLIER=1.5      # 1.5× baseline build time triggers alert
# COST_OVERPROVISIONING_THRESHOLD=0.30 # <30 % utilization = over-provisioned
# REDIS_MEMORY_PRESSURE_THRESHOLD=0.80 # 80 % memory usage = pressure
# CI_FAILURE_RATE_THRESHOLD=0.10       # >10 % failure rate → prediction alert
# BUILD_HISTORY_DAYS=30                # days of build history to analyse

# ── Retry / Circuit Breaker ────────────────────────────────────────────────────
# (all optional — defaults shown as comments)
# RETRY_MAX_ATTEMPTS=3
# RETRY_MIN_WAIT_SECONDS=2.0
# RETRY_MAX_WAIT_SECONDS=10.0
# CIRCUIT_BREAKER_FAILURE_THRESHOLD=3
# CIRCUIT_BREAKER_TIMEOUT_SECONDS=60.0

# ── API Server ─────────────────────────────────────────────────────────────────
# (all optional — defaults shown as comments)
# API_HOST=0.0.0.0
# API_PORT=8000
# API_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR | CRITICAL


