# AutoPilot AI - Environment Configuration Template
# Copy this file to .env and fill in your values

# ========== General Settings ==========
LOG_LEVEL=INFO
ENVIRONMENT=development  # development, staging, production

# ========== AWS Credentials ==========
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ========== Amazon Bedrock Model Settings ==========
# Main model for all agents (Claude 3.5 Sonnet recommended)
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Individual agent models (optional - defaults to BEDROCK_MODEL_ID)
PLANNER_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
OBSERVABILITY_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
INFRA_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
DB_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
COST_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
CICD_AGENT_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# Haiku for faster/cheaper operations
BEDROCK_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# ========== Knowledge Base Settings ==========
# Set to 'true' for local development, 'false' for AWS Knowledge Base
USE_LOCAL_KB=true
LOCAL_KB_PATH=./local_kb

# AWS Knowledge Base (required when USE_LOCAL_KB=false)
S3_BUCKET_NAME=your-knowledge-base-bucket
KNOWLEDGE_BASE_ID=your-kb-id

# ========== GitHub Integration ==========
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repo-name

# ========== CloudWatch Settings ==========
CLOUDWATCH_LOG_GROUP=/aws/autopilot-ai
CLOUDWATCH_METRICS_NAMESPACE=AutoPilotAI

# ========== Notification Settings ==========
SNS_TOPIC_ARN=arn:aws:sns:ap-south-1:123456789012:autopilot-alerts
ENABLE_NOTIFICATIONS=false  # Set to 'true' to enable SNS alerts

# ========== Cost Settings ==========
USD_TO_INR_RATE=83.0  # Update with current exchange rate

# ========== Health Check Settings ==========
# How often to check health of agents and services (in minutes)
HEALTH_CHECK_INTERVAL_MINUTES=5
HEALTH_CHECK_TIMEOUT_SECONDS=30

# ========== Scheduler Settings ==========
# How often to run periodic checks
METRIC_CHECK_INTERVAL_MINUTES=5
COST_CHECK_INTERVAL_HOURS=24
BUILD_CHECK_INTERVAL_MINUTES=15

# ========== Alert Settings ==========
# Maximum latency for critical alerts (seconds)
ALERT_LATENCY_SECONDS=60
# Statistical threshold for anomaly detection (sigma)
ANOMALY_SIGMA_THRESHOLD=2.0

# ========== API Settings ==========
API_HOST=0.0.0.0
API_PORT=8000
ENABLE_CORS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== Frontend Settings ==========
FRONTEND_URL=http://localhost:5173

# ========== AWS SDK for Bedrock Agents (Optional) ==========
# If using AWS Bedrock Agents with tool calling
BEDROCK_AGENT_ID=your-bedrock-agent-id
BEDROCK_AGENT_ALIAS_ID=your-agent-alias-id

# ========== Retry and Timeout Settings ==========
MAX_RETRIES=3
RETRY_MIN_WAIT_SECONDS=2
RETRY_MAX_WAIT_SECONDS=10
REQUEST_TIMEOUT_SECONDS=300
